<Window x:Class="Fingertippp.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fingertippp"
        Width="1360"
        Height="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="330" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="18" Padding="18">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                    <TextBlock Text="Fingertippp" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock Text="Full GUI for safe mouse latency diagnostics and optimization." Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0" TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                    <TextBlock Text="Live Devices" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="370">
                        <ItemsControl ItemsSource="{Binding Devices}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FF0F151D" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="{Binding FriendlyName}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding StatusSummary}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom">
                    <ToggleButton Content="Safe Mode" IsChecked="{Binding IsSafeModeEnabled}" Margin="0,2,0,8" Padding="12,8" Background="#FF15202B" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource PanelBorderBrush}" />
                    <ToggleButton Content="Expert Mode" IsChecked="{Binding IsExpertModeEnabled}" Margin="0,0,0,10" Padding="12,8" Background="#FF15202B" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource PanelBorderBrush}" />
                    <Button Content="Refresh Devices" Command="{Binding RefreshCommand}" Padding="12,10" Background="{StaticResource AccentBrush}" Foreground="#FF081014" BorderThickness="0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="18" Padding="20">
                <StackPanel>
                    <TextBlock Text="Optimization Status" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding SelectedDeviceSummary}" FontSize="22" FontWeight="SemiBold" Margin="0,8,0,4" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding SelectedRecommendationSummary}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding WorkflowStatusDisplay}" Margin="0,10,0,0" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding LatestActionDisplay}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0">
                <TabItem Header="Dashboard">
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="0.95*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="18" Padding="20">
                            <StackPanel>
                                <TextBlock Text="Benchmark Snapshot" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16" />
                                <UniformGrid Columns="2" Rows="2">
                                    <Border Background="#FF0F151D" CornerRadius="14" Padding="16" Margin="0,0,12,12">
                                        <StackPanel>
                                            <TextBlock Text="Confidence" Foreground="{StaticResource TextSecondaryBrush}" />
                                            <TextBlock Text="{Binding ConfidenceDisplay}" FontSize="24" FontWeight="SemiBold" Margin="0,6,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#FF0F151D" CornerRadius="14" Padding="16" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="CPS" Foreground="{StaticResource TextSecondaryBrush}" />
                                            <TextBlock Text="{Binding EstimatedCpsDisplay}" FontSize="24" FontWeight="SemiBold" Margin="0,6,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#FF0F151D" CornerRadius="14" Padding="16" Margin="0,0,12,0">
                                        <StackPanel>
                                            <TextBlock Text="Jitter" Foreground="{StaticResource TextSecondaryBrush}" />
                                            <TextBlock Text="{Binding JitterDisplay}" FontSize="24" FontWeight="SemiBold" Margin="0,6,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#FF0F151D" CornerRadius="14" Padding="16">
                                        <StackPanel>
                                            <TextBlock Text="Double Clicks" Foreground="{StaticResource TextSecondaryBrush}" />
                                            <TextBlock Text="{Binding DoubleClickDisplay}" FontSize="24" FontWeight="SemiBold" Margin="0,6,0,0" />
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <StackPanel Margin="0,18,0,0">
                                    <TextBlock Text="Active Method" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBlock Text="{Binding SelectedMethodDisplay}" FontSize="20" FontWeight="SemiBold" Margin="0,4,0,0" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="18" Padding="20">
                            <StackPanel>
                                <TextBlock Text="Quick Actions" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,14" />
                                <Button Content="Refresh + Analyze" Command="{Binding RefreshAndAnalyzeCommand}" Margin="0,0,0,10" Padding="12,10" Background="#FF1A2633" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource PanelBorderBrush}" />
                                <Button Content="Run Quick Benchmark" Command="{Binding RunQuickBenchmarkCommand}" Margin="0,0,0,10" Padding="12,10" Background="#FF1A2633" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource PanelBorderBrush}" />
                                <Button Content="Apply Safe Recommendation" Command="{Binding ApplySafeRecommendationCommand}" Padding="12,10" Background="{StaticResource AccentBrush}" Foreground="#FF081014" BorderThickness="0" />

                                <TextBlock Text="\nStatus" Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="{Binding LatestActionDisplay}" TextWrapping="Wrap" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="How To Use">
                    <Border Margin="0,12,0,0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="18" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Complete Usage Guide" FontSize="20" FontWeight="SemiBold" />
                            <TextBlock Text="Use this flow every time you connect or switch mice." Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,14" />
                            <Border Background="#FF0F151D" CornerRadius="12" Padding="14" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1">
                                <TextBlock Text="{Binding QuickStartSteps}" TextWrapping="Wrap" LineHeight="24" />
                            </Border>

                            <TextBlock Text="\nTips" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock Text="- Keep Safe Mode enabled for normal use.\n- Use Expert Mode only if you understand the tradeoffs.\n- Re-run benchmark after changing polling rate or driver settings.\n- Watch confidence + jitter together, not only CPS." TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" LineHeight="22" />
                        </StackPanel>
                    </Border>
                </TabItem>

                <TabItem Header="Safety">
                    <Border Margin="0,12,0,0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="18" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Safety and Compliance" FontSize="20" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding SafetyRules}" Margin="0,12,0,0" TextWrapping="Wrap" LineHeight="24" />
                        </StackPanel>
                    </Border>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>